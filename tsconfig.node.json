{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./out/main",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "lib": ["ESNext"],
    "types": ["electron-vite/node"]
  },
  "include": ["src/main/**/*", "src/shared/**/*"]
}
